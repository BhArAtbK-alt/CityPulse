PORT=5000
CLIENT_URL=http://localhost:5173

# Generate a strong random JWT secret (run: openssl rand -base64 64)
JWT_SECRET=your_jwt_secret_here_minimum_32_characters

# Supabase Project URL (found in Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Service Role Key (Settings → API → service_role — keep this secret!)
SUPABASE_SERVICE_KEY=eyJhbGci...your_service_role_key

# Direct PostgreSQL connection string (Settings → Database → Connection string)
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# Admin registration code — set to any secure string (admins need this to sign up)
ADMIN_SECRET_CODE=choose_a_secure_admin_code

# Super Admin registration code — ONE super admin per instance (keep very secret)
SUPER_ADMIN_CODE=choose_a_very_secure_super_admin_code
