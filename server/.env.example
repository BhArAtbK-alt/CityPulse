# =========================================================================
# CityPulse Environment Configuration Template
# =========================================================================
# Copy this file to '.env' and fill in your actual credentials.
# DO NOT commit the actual '.env' file to version control.
# =========================================================================

# --- Server Configuration ---
PORT=5000
CLIENT_URL=http://localhost:5173

# --- Authentication (JWT) ---
# Generate a strong random secret (at least 32 chars).
# Command: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_here

# --- Supabase Configuration ---
# 1. Project URL: Settings -> API -> Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# 2. Service Role Key: Settings -> API -> service_role (KEEP THIS SECRET)
# This key bypasses RLS and should only be used on the server.
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# 3. Database URL: Settings -> Database -> Connection string (Node.js)
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_ID].supabase.co:5432/postgres

# --- Admin Registration Codes ---
# These codes are required when registering a new Admin or Super Admin account.
# Set these to secure, unique strings for your deployment.
ADMIN_SECRET_CODE=choose_a_secure_admin_code
SUPER_ADMIN_CODE=choose_a_very_secure_super_admin_code

# --- AI Features (Optional) ---
# To enable AI-powered image analysis, description verification, and 
# resolution auditing, get a free Gemini API key from:
# https://aistudio.google.com/app/apikey
# Leave blank or remove this line to run without AI features.
# GEMINI_API_KEY=your_gemini_api_key_here

